---
import { BLOG_SERIES, type SeriesKey } from "../data/blogSeries";

interface Props {
  currentId: string;
}

const { currentId } = Astro.props;

// Find which series the current post belongs to
let activeSeriesKey: SeriesKey | undefined;
let activeSeries: (typeof BLOG_SERIES)[SeriesKey] | undefined;

for (const key in BLOG_SERIES) {
  const series = BLOG_SERIES[key as SeriesKey];
  if (series.posts.some((post) => post.id === currentId)) {
    activeSeriesKey = key as SeriesKey;
    activeSeries = series;
    break;
  }
}

if (!activeSeries) return null;
---

<div class="series-block">
  <div class="series-header">
    <span class="series-badge">SERIES</span>
    <h2 class="series-title">{activeSeries.title}</h2>
  </div>
  <ol class="series-list">
    {
      activeSeries.posts.map((post, index) => {
        const isCurrent = post.id === currentId;
        return (
          <li class:list={["series-item", { "is-current": isCurrent }]}>
            <span class="item-number">{index + 1}</span>
            {isCurrent ? (
              <span class="item-link">
                <span class="item-title">{post.title}</span>
                <span class="current-indicator">OPEN</span>
              </span>
            ) : (
              <a href={`/${post.id}/`} class="item-link">
                <span class="item-title">{post.title}</span>
              </a>
            )}
          </li>
        );
      })
    }
  </ol>
</div>

<style>
  .series-block {
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 8px;
  }

  .series-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--sl-color-hairline);
  }

  .series-badge {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.1rem 0.4rem;
    background: var(--sl-color-text-accent);
    color: white;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .series-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--sl-color-text);
    margin: 0;
  }

  .series-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .series-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .item-number {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--sl-color-gray-3);
    background: var(--sl-color-bg-inline-code);
    border-radius: 50%;
    margin-top: 0.125rem;
  }

  .is-current .item-number {
    background: var(--sl-color-text-accent);
    color: white;
  }

  .item-link {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--sl-color-text-muted);
    transition: color 0.15s;
  }

  a.item-link:hover {
    color: var(--sl-color-text-accent);
    text-decoration: underline;
  }

  .is-current .item-link {
    color: var(--sl-color-text);
    font-weight: 600;
  }

  .current-indicator {
    font-size: 0.7rem;
    color: var(--sl-color-text-accent);
    background: var(--sl-color-accent-low);
    padding: 0.05rem 0.3rem;
    border-radius: 4px;
    font-weight: 700;
    white-space: nowrap;
  }

  .item-title {
    flex: 1;
    min-width: 0;
  }
</style>
