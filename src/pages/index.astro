---
import { getCollection } from "astro:content";
import PageLayout from "../components/PageLayout.astro";
import { getHue } from "../data/tagColors";

const allBlogPosts = await getCollection("docs", ({ id, data }) => {
  return id.startsWith("blog/") && !data.draft;
});

const allDocs = await getCollection("docs", ({ id, data }) => {
  return id.startsWith("docs/") && id.split("/").length >= 3 && !data.draft;
});

const latestBlogPosts = allBlogPosts
  .filter((p) => p.data.date)
  .sort((a, b) => {
    const aDate = new Date(a.data.lastUpdated ?? a.data.date ?? 0);
    const bDate = new Date(b.data.lastUpdated ?? b.data.date ?? 0);
    return bDate.getTime() - aDate.getTime();
  })
  .slice(0, 6);

const DOCS_PAGE_SIZE = 12;
const DOCS_MAX = 48;

const latestDocs = allDocs
  .filter((d) => d.data.lastUpdated)
  .sort((a, b) => {
    const aDate = new Date(a.data.lastUpdated ?? 0);
    const bDate = new Date(b.data.lastUpdated ?? 0);
    return bDate.getTime() - aDate.getTime();
  })
  .slice(0, DOCS_MAX);

function formatDate(date: Date | string | undefined) {
  if (!date) return "";
  return new Date(date).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<PageLayout
  title="vlow.log"
  description="vlow.log - Backend Engineer, Java & Spring"
  canonical="https://sgn07124.github.io/"
  sitemap={true}
  ogTitle="vlow.log"
  ogDescription="Backend Engineer, Java & Spring"
  ogUrl="https://sgn07124.github.io/"
>
  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="container hero-content">
        <p class="hero-eyebrow animate-fade-in-up">Backend Engineer</p>
        <h1 class="hero-name animate-fade-in-up" style="animation-delay: 60ms;">
          kyungho
        </h1>
        <p class="role animate-fade-in-up" style="animation-delay: 120ms;">
          Java & Spring · Building reliable systems
        </p>
        <div
          class="hero-links animate-fade-in-up"
          style="animation-delay: 240ms;"
        >
          <a href="/about/" class="btn btn-primary">
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M12 12c2.761 0 5-2.239 5-5s-2.239-5-5-5-5 2.239-5 5 2.239 5 5 5zm0 2c-3.337 0-10 1.676-10 5v2h20v-2c0-3.324-6.663-5-10-5z"
              ></path>
            </svg>
            About Me
          </a>
          <a
            href="https://github.com/sgn07124"
            class="btn"
            target="_blank"
            rel="noopener"
          >
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
            GitHub
          </a>
        </div>
      </div>
    </section>

    <!-- Explore -->
    <section class="section observe-fade">
      <div class="container">
        <div class="section-header">
          <h2>Explore</h2>
        </div>
        <div class="explore-grid">
          <a href="/blog/" class="explore-card">
            <div class="explore-icon" aria-hidden="true">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M12 20h9"></path><path
                  d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
              </svg>
            </div>
            <div class="explore-body">
              <div class="explore-name">Blog</div>
              <div class="explore-desc">
                기술적 경험과 시행착오, 개선 과정 기록
              </div>
            </div>
            <span class="explore-arrow" aria-hidden="true">→</span>
          </a>
          <a href="/docs/" class="explore-card">
            <div class="explore-icon" aria-hidden="true">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path
                  d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"
                ></path>
              </svg>
            </div>
            <div class="explore-body">
              <div class="explore-name">Docs</div>
              <div class="explore-desc">단순 지식이나 개념 기록</div>
            </div>
            <span class="explore-arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Latest Posts -->
    <section class="section observe-fade">
      <div class="container">
        <div class="section-header">
          <h2>Recently Updated · Blog</h2>
          <a href="/blog/" class="section-link">All posts →</a>
        </div>
        {
          latestBlogPosts.length > 0 ? (
            <ul class="post-list">
              {latestBlogPosts.map((post, i) => {
                const tag = (post.data.tags as string[] | undefined)?.[0];
                const description = (
                  post.data.description as string | undefined
                )?.trim();
                return (
                  <li style={`animation-delay: ${i * 50}ms`}>
                    <a href={`/${post.id}/`} class="post-row">
                      {tag ? (
                        <span
                          class="post-tag"
                          style={`--tag-hue:${getHue(tag)}`}
                        >
                          {tag}
                        </span>
                      ) : (
                        <span />
                      )}
                      <span class="post-title">{post.data.title}</span>
                      <span class="post-date">
                        {formatDate(
                          (post.data.lastUpdated as Date | undefined) ??
                            post.data.date,
                        )}
                      </span>
                      <span class="post-arrow">→</span>
                      {description && (
                        <span class="post-tooltip" role="tooltip">
                          {description}
                        </span>
                      )}
                    </a>
                  </li>
                );
              })}
            </ul>
          ) : (
            <p style="color: var(--color-text-muted); font-size: 0.9rem;">
              포스팅 준비 중입니다.
            </p>
          )
        }
      </div>
    </section>

    <!-- Recent Docs -->
    <section class="section observe-fade">
      <div class="container">
        <div class="section-header">
          <h2>Recently Updated · Docs</h2>
          <a href="/docs/" class="section-link">All docs →</a>
        </div>
        {
          latestDocs.length > 0 ? (
            <>
              <ul
                class="post-list"
                data-doc-list
                data-page-size={DOCS_PAGE_SIZE}
              >
                {latestDocs.map((doc, i) => {
                  const tag = (doc.data.tags as string[] | undefined)?.[0];
                  const description = (
                    doc.data.description as string | undefined
                  )?.trim();
                  return (
                    <li
                      class={i >= DOCS_PAGE_SIZE ? "is-hidden" : "is-revealed"}
                      style={`animation-delay: ${(i % DOCS_PAGE_SIZE) * 110}ms`}
                    >
                      <a href={`/${doc.id}/`} class="post-row">
                        {tag ? (
                          <span
                            class="post-tag"
                            style={`--tag-hue:${getHue(tag)}`}
                          >
                            {tag}
                          </span>
                        ) : (
                          <span />
                        )}
                        <span class="post-title">{doc.data.title}</span>
                        <span class="post-date">
                          {formatDate(doc.data.lastUpdated as Date | undefined)}
                        </span>
                        <span class="post-arrow">→</span>
                        {description && (
                          <span class="post-tooltip" role="tooltip">
                            {description}
                          </span>
                        )}
                      </a>
                    </li>
                  );
                })}
              </ul>
              {latestDocs.length > DOCS_PAGE_SIZE && (
                <>
                  <div
                    class="docs-sentinel"
                    data-docs-sentinel
                    aria-hidden="true"
                  />
                  <a href="/docs/" class="docs-end-cta is-hidden" data-docs-cta>
                    <span class="docs-end-cta-label">View all docs</span>
                    <span class="docs-end-cta-arrow" aria-hidden="true">
                      →
                    </span>
                  </a>
                </>
              )}
            </>
          ) : (
            <p style="color: var(--color-text-muted); font-size: 0.9rem;">
              문서 마이그레이션 준비 중입니다.
            </p>
          )
        }
      </div>
    </section>
  </main>

  <Fragment slot="footer">
    <p>
      © {new Date().getFullYear()} vlow.log · Built with Astro & Starlight
    </p>
  </Fragment>
</PageLayout>

<style>
  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 1.15rem;
    border-radius: var(--t-radius-md);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    transition: all var(--t-duration) var(--t-ease);
    box-shadow: var(--t-shadow-sm);
  }

  .btn-primary {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
    box-shadow:
      var(--t-shadow-sm),
      0 0 0 0 var(--color-accent-glow);
  }

  .btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-light);
    transform: translateY(-1px);
    box-shadow: var(--t-shadow-md);
  }

  .btn-primary:hover {
    color: #fff;
    box-shadow: var(--t-shadow-md), var(--t-shadow-glow);
    transform: translateY(-1px);
  }

  /* ── Hero ── */
  .hero {
    position: relative;
    padding: 6rem 0 4rem;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: var(--t-gradient-hero);
    pointer-events: none;
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 1rem;
  }

  .hero-name {
    font-size: clamp(2.6rem, 6vw, 3.6rem);
    font-weight: 800;
    margin: 0 0 1rem;
    line-height: 1.15;
    letter-spacing: -0.03em;
    background: var(--t-gradient-accent);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero .role {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    margin: 0 0 2rem;
    font-weight: 400;
    line-height: 1.5;
  }

  .hero-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* ── Section ── */
  .section {
    padding: 2.75rem 0;
    border-top: 1px solid var(--color-border);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
  }

  .section-header h2 {
    font-size: 0.78rem;
    font-weight: 650;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .section-header h2::before {
    content: "";
    display: inline-block;
    width: 3px;
    height: 14px;
    border-radius: 2px;
    background: var(--t-gradient-accent);
    flex-shrink: 0;
  }

  .section-link {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--t-duration) var(--t-ease);
    font-weight: 450;
  }

  .section-link:hover {
    color: var(--color-accent-light);
  }

  /* ── Explore ── */
  .explore-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.85rem;
  }

  @media (max-width: 480px) {
    .explore-grid {
      grid-template-columns: 1fr;
    }
  }

  .explore-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.35rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--t-radius-md);
    text-decoration: none;
    color: var(--color-text);
    transition: all var(--t-duration) var(--t-ease);
    box-shadow: var(--t-shadow-sm);
    position: relative;
    overflow: hidden;
  }

  .explore-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--t-gradient-card);
    opacity: 0;
    transition: opacity var(--t-duration) var(--t-ease);
  }

  .explore-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: var(--t-shadow-md), var(--t-shadow-glow);
  }

  .explore-card:hover::before {
    opacity: 1;
  }

  .explore-icon {
    flex-shrink: 0;
    width: 38px;
    height: 38px;
    border-radius: var(--t-radius-sm);
    background: var(--color-accent-glow);
    color: var(--color-accent-light);
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      transform var(--t-duration) var(--t-ease-bounce),
      background var(--t-duration) var(--t-ease);
    position: relative;
    z-index: 1;
  }

  .explore-card:hover .explore-icon {
    transform: translateY(-2px);
    background: var(--t-accent-glow-strong);
  }

  .explore-body {
    flex: 1;
    min-width: 0;
    position: relative;
    z-index: 1;
  }

  .explore-name {
    font-size: 0.94rem;
    font-weight: 600;
    margin-bottom: 0.2rem;
    letter-spacing: -0.01em;
  }

  .explore-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.45;
  }

  .explore-arrow {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    transition:
      transform var(--t-duration) var(--t-ease),
      color var(--t-duration) var(--t-ease);
    position: relative;
    z-index: 1;
  }

  .explore-card:hover .explore-arrow {
    transform: translateX(3px);
    color: var(--color-accent-light);
  }

  /* ── Post / Doc rows ── */
  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-row {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0.5rem;
    margin: 0 -0.5rem;
    border-radius: var(--t-radius-sm);
    text-decoration: none;
    color: var(--color-text);
    transition: all var(--t-duration-fast) var(--t-ease);
    position: relative;
  }

  .post-row::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 0;
    border-radius: 2px;
    background: var(--t-gradient-accent);
    transition: height var(--t-duration) var(--t-ease);
  }

  .post-list li + li .post-row {
    border-top: 1px solid
      color-mix(in srgb, var(--color-border) 60%, transparent);
  }

  .post-row:hover {
    background: var(--color-accent-glow);
    color: var(--color-accent-light);
  }

  .post-row:hover::before {
    height: 60%;
  }

  .post-row:hover .post-date {
    color: var(--color-accent-light);
  }

  .post-tag {
    font-size: 0.7rem;
    padding: 0.18rem 0.5rem;
    border-radius: 4px;
    white-space: nowrap;
    font-weight: 500;
    background: hsl(var(--tag-hue, 220), 55%, 18%);
    color: hsl(var(--tag-hue, 220), 78%, 72%);
    transition: transform var(--t-duration-fast) var(--t-ease);
  }

  :global([data-theme="light"]) .post-tag {
    background: hsl(var(--tag-hue, 220), 58%, 93%);
    color: hsl(var(--tag-hue, 220), 55%, 35%);
  }

  .post-title {
    font-size: 0.9rem;
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    letter-spacing: -0.01em;
  }

  .post-date {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    font-family: ui-monospace, "SF Mono", "Fira Code", monospace;
    color: var(--color-text-muted);
    white-space: nowrap;
    transition: color var(--t-duration-fast) var(--t-ease);
  }

  .post-arrow {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    transition:
      transform var(--t-duration) var(--t-ease),
      color var(--t-duration) var(--t-ease);
  }

  .post-row:hover .post-arrow {
    transform: translateX(3px);
    color: var(--color-accent-light);
  }

  @media (max-width: 540px) {
    .post-row {
      grid-template-columns: auto 1fr auto;
    }
    .post-date {
      display: none;
    }
  }

  /* ── Tooltip (description on hover) ── */
  .post-tooltip {
    position: absolute;
    top: calc(100% - 2px);
    left: 50%;
    transform: translate(-50%, 4px);
    z-index: 50;
    isolation: isolate;

    width: max-content;
    max-width: min(420px, calc(100vw - 2rem));
    padding: 0.7rem 0.95rem;

    background: var(--color-surface-high);
    border: 1px solid
      color-mix(in srgb, var(--color-border) 80%, var(--color-text) 20%);
    border-radius: var(--t-radius-sm);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.25),
      0 8px 24px rgba(0, 0, 0, 0.45);

    font-size: 0.78rem;
    line-height: 1.55;
    font-weight: 400;
    color: var(--color-text);
    letter-spacing: -0.005em;
    white-space: normal;
    text-align: left;

    opacity: 0;
    pointer-events: none;
    transition:
      opacity var(--t-duration) var(--t-ease),
      transform var(--t-duration) var(--t-ease);
  }

  :global([data-theme="light"]) .post-tooltip {
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.06),
      0 8px 24px rgba(0, 0, 0, 0.12);
  }

  @media (hover: hover) {
    .post-row:hover .post-tooltip {
      opacity: 1;
      transform: translate(-50%, 0);
      transition-delay: 120ms;
    }
  }

  @media (hover: none) {
    .post-tooltip {
      display: none;
    }
  }

  /* ── Infinite scroll ── */
  .post-list li.is-hidden {
    display: none;
  }

  @keyframes postFadeIn {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .post-list li.is-revealed,
  .docs-end-cta.is-revealed {
    animation: postFadeIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @media (prefers-reduced-motion: reduce) {
    .post-list li.is-revealed,
    .docs-end-cta.is-revealed {
      animation: none;
    }
  }

  .docs-sentinel {
    height: 1px;
    width: 100%;
  }

  .docs-end-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
    padding: 0.95rem 1.25rem;
    border: 1px dashed var(--color-border);
    border-radius: var(--t-radius-md);
    text-decoration: none;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    transition: all var(--t-duration) var(--t-ease);
  }

  .docs-end-cta:hover {
    border-style: solid;
    border-color: var(--color-accent);
    color: var(--color-accent-light);
    background: var(--color-accent-glow);
  }

  .docs-end-cta-arrow {
    transition: transform var(--t-duration) var(--t-ease);
  }

  .docs-end-cta:hover .docs-end-cta-arrow {
    transform: translateX(4px);
  }

  .docs-end-cta.is-hidden {
    display: none;
  }
</style>

<script>
  // Clear `is-revealed` after animation completes on any animated row/CTA.
  // The animation's transform creates a stacking context that traps the
  // tooltip — removing the class drops the animation property and the
  // stacking context with it, while fill-mode keeps no lasting effect since
  // the end state matches default styles.
  document.addEventListener("animationend", (e) => {
    const target = e.target as HTMLElement | null;
    if (!target) return;
    if (
      target.matches(".post-list li.is-revealed, .docs-end-cta.is-revealed")
    ) {
      target.classList.remove("is-revealed");
    }
  });

  const list = document.querySelector<HTMLElement>("[data-doc-list]");
  const sentinel = document.querySelector<HTMLElement>("[data-docs-sentinel]");
  const cta = document.querySelector<HTMLElement>("[data-docs-cta]");
  if (list && sentinel) {
    const pageSize = Number(list.dataset.pageSize ?? 12);
    const items = Array.from(list.children) as HTMLElement[];
    let shown = pageSize;

    const observer = new IntersectionObserver(
      (entries) => {
        if (!entries[0].isIntersecting) return;
        const next = Math.min(shown + pageSize, items.length);
        for (let i = shown; i < next; i++) {
          const item = items[i];
          const localIndex = i - shown;
          item.style.animationDelay = `${localIndex * 110}ms`;
          item.classList.remove("is-hidden");
          item.classList.add("is-revealed");
        }
        shown = next;
        if (shown >= items.length) {
          observer.disconnect();
          if (cta) {
            const lastItemDelay = (next - 1 - (next - pageSize)) * 110;
            cta.style.animationDelay = `${lastItemDelay + 200}ms`;
            cta.classList.remove("is-hidden");
            cta.classList.add("is-revealed");
          }
        }
      },
      { rootMargin: "0px 0px -10% 0px" },
    );

    observer.observe(sentinel);
  }
</script>
